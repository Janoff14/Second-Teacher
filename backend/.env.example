# Copy to .env and adjust values. Never commit .env (real secrets).
# cp .env.example .env

NODE_ENV=development

# API listen (Railway injects PORT; HOST is optional)
PORT=4000
HOST=0.0.0.0

# Generate a strong random string for production (min 16 characters).
JWT_SECRET=dev-only-change-me-16chars

# Comma-separated browser origins allowed for CORS
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

LOG_LEVEL=info
AGENT_TOOL_TIMEOUT_MS=2500

# OpenAI (chat, embeddings, RAG) — optional for some flows
OPENAI_API_KEY=

# Supabase — optional until you wire persistence
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only; bypasses RLS. Do not expose to the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# true | false; defaults to false outside tests
SEED_DEFAULT_USERS=false
SEED_DEMO_DATA=false

# Required when SEED_DEFAULT_USERS or SEED_DEMO_DATA is enabled outside tests.
DEFAULT_ADMIN_PASSWORD=
EXTRA_ADMIN_PASSWORD=
DEFAULT_TEACHER_PASSWORD=
DEFAULT_STUDENT_PASSWORD=
DEMO_STUDENT_PASSWORD=

# --- Scripts only (prod-route-check, smoke-deploy, verify-openai-key) ---
# API_BASE_URL=https://your-api.example.com
# SMOKE_EMAIL=admin@example.com
# SMOKE_PASSWORD=
# OPENAI_SMOKE_MODEL=gpt-4o-mini
