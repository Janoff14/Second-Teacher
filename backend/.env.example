NODE_ENV=development
PORT=4000
# Listen address (use 0.0.0.0 on Railway/Docker so healthchecks can reach the process)
# HOST=0.0.0.0
#
# Railway: do NOT copy PORT=4000 into service Variables if Networking shows another port (e.g. 8090).
# Either delete PORT from Variables (let Railway set it) or set PORT to the same number as Networking.
JWT_SECRET=replace-with-strong-secret
# Comma-separated; add both so login works from http://localhost:3000 and http://127.0.0.1:3000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=info
AGENT_TOOL_TIMEOUT_MS=2500

# Optional — only when you integrate OpenAI (LLM, embeddings, etc.)
# OPENAI_API_KEY=
# Optional — override for `npm run verify-openai` (default gpt-4o-mini)
# OPENAI_SMOKE_MODEL=gpt-4o-mini

# Supabase (optional until you wire DB/storage)
# Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Anon or "publishable" key — respects RLS
SUPABASE_ANON_KEY=
# Service role / secret key — bypasses RLS; server-only, never commit. Add when you need admin jobs or Storage without user JWT.
SUPABASE_SERVICE_ROLE_KEY=

# Smoke-test deployed API (local CLI only; do not commit real prod secrets)
# API_BASE_URL=https://your-service.up.railway.app
# SMOKE_EMAIL=admin@secondteacher.dev
# SMOKE_PASSWORD=ChangeMe123!
