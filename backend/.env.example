NODE_ENV=development
PORT=4000
# Listen address (use 0.0.0.0 on Railway/Docker so healthchecks can reach the process)
# HOST=0.0.0.0
JWT_SECRET=replace-with-strong-secret
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
AGENT_TOOL_TIMEOUT_MS=2500

# Optional — only when you integrate OpenAI (LLM, embeddings, etc.)
# OPENAI_API_KEY=
# Optional — override for `npm run verify-openai` (default gpt-4o-mini)
# OPENAI_SMOKE_MODEL=gpt-4o-mini

# Supabase (optional until you wire DB/storage)
# Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Anon or "publishable" key — respects RLS
SUPABASE_ANON_KEY=
# Service role / secret key — bypasses RLS; server-only, never commit. Add when you need admin jobs or Storage without user JWT.
SUPABASE_SERVICE_ROLE_KEY=

# Railway sets PORT in production; you normally do not set it there.
